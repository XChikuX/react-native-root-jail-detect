{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["rootjaildetect"],
  "ios": {
    "iosModuleName": "RootJailDetect"
  },
  "android": {
    "androidNamespace": ["rootjaildetect"],
    "androidCxxLibName": "RootJailDetect"
  },
  "autolinking": {
    "RootJailDetect": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridRootJailDetect"
      }
    },
    "SecurityWatchdog": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridSecurityWatchdog"
      }
    }
  },
  "ignorePaths": ["**/node_modules", "**/example", "**/lib"],
  "gitAttributesGeneratedFlag": true
}
